{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./gen/srv",
    "rootDir": ".",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "#cds-models/*": ["./@cds-models/*/index.ts"]
    },
    "types": ["node", "jest"]
  },
  "include": [
    "srv/**/*.ts",
    "lib/**/*.ts",
    "test/**/*.ts",
    "@cds-models/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "gen"
  ]
}
