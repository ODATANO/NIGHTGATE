{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": ".",
        "sourceMap": false,
        "declarationMap": false,
        "types": [
            "node",
            "@cap-js/cds-types"
        ]
    },
    "include": [
        "src/**/*.ts",
        "srv/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "gen",
        "coverage",
        "test",
        "@cds-models"
    ]
}