{
  "name": "@odatano/nightgate",
  "version": "0.1.2",
  "description": "CAP Plugin — Midnight Blockchain Indexer with OData V4 API",
  "homepage": "https://github.com/ODATANO/ODATANO-NIGHT/tree/main/packages/indexer",
  "repository": {
    "type": "git",
    "url": "https://github.com/ODATANO/ODATANO-NIGHT.git",
    "directory": "packages/indexer"
  },
  "license": "Apache-2.0",
  "author": "Max Weber <max@maxalexweber.de>",
  "keywords": [
    "sap",
    "cap",
    "cds-plugin",
    "midnight",
    "cardano",
    "blockchain",
    "indexer",
    "odata",
    "enterprise",
    "crawler",
    "substrate"
  ],
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./types": {
      "types": "./srv/types/index.d.ts",
      "default": "./srv/types/index.js"
    }
  },
  "files": [
    "cds-plugin.js",
    "db/schema.cds",
    "src/**/*.js",
    "src/**/*.d.ts",
    "srv/**/*.cds",
    "srv/**/*.js",
    "srv/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node scripts/clean-build-artifacts.js",
    "prestart": "npm run build",
    "start": "npm run serve",
    "dev": "npm run cds:watch",
    "build": "npm run build:plugin",
    "build:plugin": "npm run cds:types && tsc -p tsconfig.build.json",
    "serve": "npm run cds:serve",
    "cds:watch": "cds watch",
    "cds:serve": "cds-serve",
    "cds:types": "cds-typer \"*\" --outputDirectory @cds-models",
    "build:types": "npm run cds:types",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy": "cds deploy",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=test/unit",
    "lint": "eslint .",
    "prepack": "npm run build:plugin",
    "prepublishOnly": "npm run typecheck && npm test && npm run build:plugin"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "express": "^4",
    "ws": "^8"
  },
  "peerDependencies": {
    "@sap/cds": ">=9.0.0"
  },
  "devDependencies": {
    "@cap-js/cds-typer": "^0.38.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds": "^9",
    "@sap/cds-dk": "^9",
    "@types/jest": "^29",
    "@types/node": "^22",
    "@types/ws": "^8",
    "eslint": "^9.39.3",
    "jest": "^29",
    "ts-jest": "^29",
    "tsx": "^4",
    "typescript": "^5"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "database": "db/midnight.db"
        }
      },
      "nightgate": {
        "kind": "nightgate"
      },
      "kinds": {}
    },
    "[development]": {
      "requires": {
        "auth": {
          "kind": "dummy"
        }
      }
    },
    "odata": {
      "version": "v4"
    },
    "typer": {
      "outputDirectory": "@cds-models"
    }
  }
}