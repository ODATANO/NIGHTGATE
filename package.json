{
  "name": "@odatano/nightgate",
  "version": "0.6.3",
  "description": "CAP Plugin: Midnight Blockchain Indexer with OData V4 API",
  "homepage": "https://github.com/ODATANO/NIGHTGATE#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ODATANO/NIGHTGATE.git"
  },
  "license": "Apache-2.0",
  "author": "Max Weber <max@maxalexweber.de>",
  "keywords": [
    "sap",
    "cap",
    "cds-plugin",
    "midnight",
    "cardano",
    "blockchain",
    "indexer",
    "odata",
    "enterprise",
    "crawler",
    "substrate"
  ],
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./cds-plugin": "./cds-plugin.js",
    "./cds-plugin.js": "./cds-plugin.js",
    "./package.json": "./package.json",
    "./types": {
      "types": "./srv/types/index.d.ts",
      "default": "./srv/types/index.js"
    },
    "./sdk/AttestationService": {
      "types": "./src/sdk/AttestationService.d.ts",
      "default": "./src/sdk/AttestationService.js"
    },
    "./sdk/AttestationService.cds": "./src/sdk/AttestationService.cds",
    "./browser": {
      "types": "./src/browser/index.d.ts",
      "import": "./src/browser/index.mjs",
      "default": "./src/browser/index.mjs"
    },
    "./browser/attestation-vault": {
      "types": "./contracts/attestation-vault/src/managed/attestation-vault/contract/index.d.ts",
      "import": "./contracts/attestation-vault/src/managed/attestation-vault/contract/index.js",
      "default": "./contracts/attestation-vault/src/managed/attestation-vault/contract/index.js"
    }
  },
  "files": [
    "cds-plugin.js",
    "db/schema.cds",
    "db/types.cds",
    "src/**/*.cds",
    "src/**/*.js",
    "src/**/*.mjs",
    "src/**/*.d.ts",
    "srv/**/*.cds",
    "srv/**/*.js",
    "srv/**/*.d.ts",
    "@cds-models/**/*.js",
    "@cds-models/**/*.d.ts",
    "contracts/**/managed/**/*",
    "contracts/**/package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node scripts/clean-build-artifacts.js",
    "prestart": "npm run build",
    "start": "npm run serve",
    "dev": "node scripts/dev.mjs",
    "dev:default-heap": "npm run cds:watch",
    "build": "npm run build:plugin",
    "build:plugin": "npm run cds:types && tsc -p tsconfig.build.json",
    "serve": "npm run cds:serve",
    "serve:sync": "node scripts/serve.mjs",
    "sync:start": "node --env-file=.env scripts/start-wallet-sync.mjs",
    "sync:probe": "node scripts/probe-indexer.mjs",
    "cds:watch": "cds watch",
    "cds:serve": "cds-serve",
    "cds:types": "cds-typer \"*\" --outputDirectory @cds-models --outputDTsFiles false",
    "build:types": "npm run cds:types",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy": "cds deploy --to sqlite:db/midnight.db",
    "pretest": "npm run build",
    "test": "jest --coverage --runInBand",
    "test:unit": "npm run build && jest --testPathPattern=test/unit --runInBand",
    "smoke:sdk": "node scripts/smoke-test-sdk.mjs",
    "integration:providers": "node scripts/integration-test-providers.mjs",
    "integration:wallet-keys": "node scripts/integration-test-wallet-keys.mjs",
    "integration:wallet-facade": "node scripts/integration-test-wallet-facade.mjs",
    "integration:contract-registry": "node scripts/integration-test-contract-registry.mjs",
    "integration:connector-routes": "node scripts/integration-test-connector-routes.mjs",
    "check:browser": "node scripts/check-browser-bundle.mjs",
    "integration:attestation-vault": "node scripts/integration-test-attestation-vault.mjs",
    "deploy:e2e": "node --env-file=.env scripts/run-deploy-e2e.mjs",
    "predicate:e2e": "node --env-file=.env scripts/run-predicate-e2e.mjs",
    "disclosure:e2e": "node --env-file=.env scripts/run-disclosure-e2e.mjs",
    "state-verify:e2e": "node --env-file=.env scripts/run-state-verification-e2e.mjs",
    "lint": "eslint .",
    "prepack": "npm run build:plugin",
    "prepublishOnly": "npm run typecheck && npm test && npm run build:plugin"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "^2.5.0",
    "@midnight-ntwrk/compact-runtime": "^0.16.0",
    "@midnight-ntwrk/ledger-v8": "^8.1.0",
    "@midnight-ntwrk/midnight-js-contracts": "^4.0.4",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-network-id": "^4.0.4",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "^4.0.4",
    "@midnight-ntwrk/wallet-sdk-address-format": "npm:@midnightntwrk/wallet-sdk-address-format@^3.1.2",
    "@midnightntwrk/wallet-sdk-abstractions": "^2.1.0",
    "@midnightntwrk/wallet-sdk-address-format": "^3.1.2",
    "@midnightntwrk/wallet-sdk-dust-wallet": "^4.2.0",
    "@midnightntwrk/wallet-sdk-facade": "^4.1.0",
    "@midnightntwrk/wallet-sdk-hd": "^3.0.3",
    "@midnightntwrk/wallet-sdk-shielded": "^3.0.2",
    "@midnightntwrk/wallet-sdk-unshielded-wallet": "^3.1.0",
    "@noble/hashes": "^1.8.0",
    "bip39": "^3.1.0",
    "express": "^4",
    "undici": "^8.3.0",
    "ws": "^8"
  },
  "peerDependencies": {
    "@sap/cds": ">=9.0.0",
    "@midnight-ntwrk/dapp-connector-api": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@midnight-ntwrk/dapp-connector-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1",
    "@cap-js/cds-typer": "^0.40.0",
    "@cap-js/cds-types": "^0.18.0",
    "@cap-js/sqlite": "^3",
    "@sap/cds": "^10",
    "@sap/cds-dk": "^10",
    "@types/jest": "^29",
    "@types/node": "^22",
    "@types/ws": "^8",
    "eslint": "^10",
    "globals": "^14.0.0",
    "jest": "^29",
    "ts-jest": "^29",
    "tsx": "^4",
    "typescript": "^5"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/midnight.db"
        }
      },
      "nightgate": {
        "kind": "nightgate",
        "contracts": {
          "counter": {
            "artifactPath": "contracts/counter/src/managed/counter/contract/index.js",
            "privateStateId": "counterPrivateState",
            "zkConfigPath": "contracts/counter/src/managed/counter"
          },
          "attestation-vault": {
            "artifactPath": "contracts/attestation-vault/src/managed/attestation-vault/contract/index.js",
            "privateStateId": "attestationVaultPrivateState",
            "zkConfigPath": "contracts/attestation-vault/src/managed/attestation-vault"
          }
        }
      },
      "kinds": {}
    },
    "[development]": {
      "requires": {
        "auth": {
          "kind": "dummy"
        }
      }
    },
    "[test]": {
      "requires": {
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          }
        },
        "auth": {
          "kind": "dummy"
        }
      }
    },
    "odata": {
      "version": "v4"
    },
    "typer": {
      "outputDirectory": "@cds-models"
    }
  }
}