{
  "name": "@odatano/night-indexer",
  "version": "1.0.0-beta.1",
  "description": "CAP Plugin — Midnight Blockchain Indexer with OData V4 API",
  "homepage": "https://github.com/ODATANO/ODATANO-NIGHT/tree/main/packages/indexer",
  "repository": {
    "type": "git",
    "url": "https://github.com/ODATANO/ODATANO-NIGHT.git",
    "directory": "packages/indexer"
  },
  "license": "Apache-2.0",
  "author": "Max Weber <max@maxalexweber.de>",
  "keywords": [
    "sap",
    "cap",
    "cds-plugin",
    "midnight",
    "cardano",
    "blockchain",
    "indexer",
    "odata",
    "enterprise",
    "crawler",
    "substrate"
  ],
  "main": "cds-plugin.js",
  "types": "lib/types/index.d.ts",
  "files": [
    "cds-plugin.js",
    "db/",
    "srv/",
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "build": "tsc",
    "build:types": "cds-typer '*' --outputDirectory @cds-models",
    "deploy": "cds deploy",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=test/unit",
    "lint": "eslint .",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "express": "^4",
    "ws": "^8"
  },
  "peerDependencies": {
    "@sap/cds": ">=9.0.0"
  },
  "devDependencies": {
    "@cap-js/cds-typer": "^0.38.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds": "^9",
    "@sap/cds-dk": "^9",
    "@types/jest": "^29",
    "@types/node": "^22",
    "@types/ws": "^8",
    "jest": "^29",
    "ts-jest": "^29",
    "tsx": "^4",
    "typescript": "^5"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "database": "db/midnight.db"
        }
      },
      "midnight": {
        "kind": "midnight",
        "network": "testnet",
        "nodeUrl": "ws://localhost:9944"
      },
      "kinds": {
        "midnight": {
          "impl": "./lib/types/midnight.js"
        }
      }
    },
    "odata": {
      "version": "v4"
    },
    "typer": {
      "outputDirectory": "@cds-models"
    }
  }
}
