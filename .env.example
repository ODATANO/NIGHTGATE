# ── Preprod (default — works out of the box, no Docker needed) ──
# No .env required. The code defaults to preprod + public RPC.
# Uncomment below only if you want to be explicit:
# NIGHTGATE_NETWORK=preprod
# NIGHTGATE_NODE_URL=wss://rpc.preprod.midnight.network/

# ── Testnet with local Docker node ──
# docker compose -f docker/docker-compose.yml up -d
# NIGHTGATE_NETWORK=testnet
# NIGHTGATE_NODE_URL=ws://localhost:9944

# ── Preprod with local Docker node (own full node) ──
# NIGHTGATE_NETWORK=preprod
# NIGHTGATE_NODE_URL=ws://localhost:9944
