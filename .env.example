# ──────────────────────────────────────────────────────────────────────────
# NIGHTGATE — environment variables
#
# All variables are OPTIONAL except ENCRYPTION_KEY (required in production)
# and the LACE_* keys (required only for the wallet-sync / T15 scripts).
# Defaults are baked into the code; uncomment a line only if you want to
# override the default.
# ──────────────────────────────────────────────────────────────────────────

# ── Network & node ────────────────────────────────────────────────────────
NIGHTGATE_NETWORK=preprod                              # preprod | testnet | mainnet
NIGHTGATE_NODE_URL=wss://rpc.preprod.midnight.network/
# NIGHTGATE_CRAWLER_NODE_URL=                          # falls back to NIGHTGATE_NODE_URL

# Disable the block crawler (useful when running submission tests in isolation)
# NIGHTGATE_CRAWLER_ENABLED=false

# ── Midnight Indexer (GraphQL) ────────────────────────────────────────────
# Defaults route to the PUBLIC hosted indexer for the configured network
# (https://indexer.<network>.midnight.network/api/v4/graphql). This is the
# recommended setting for live submission: the wallet reads block timestamps
# from the indexer to set the dust `ctime`, so the indexer MUST be at the chain
# tip. A lagging indexer makes every submission fail with
# `1010 Invalid Transaction: Custom error: 170` (dust validity window).
#
# The local container (docker/docker-compose.yml, indexer-standalone on :8088)
# gives a more stable WS subscription, BUT it syncs from genesis at only
# ~1.8 blocks/sec and can fall days behind the tip — do NOT point at it for live
# deploys unless `caught_up:true` AND current (check: npm run sync:probe).
# NIGHTGATE_INDEXER_HTTP_URL=http://localhost:8088/api/v4/graphql
# NIGHTGATE_INDEXER_WS_URL=ws://localhost:8088/api/v4/graphql/ws

# ── Submission stack ──────────────────────────────────────────────────────
# Proof server (compose: midnightntwrk/proof-server on :6300)
# NIGHTGATE_PROOF_SERVER_URL=http://localhost:6300
# NIGHTGATE_ZK_CONFIG_BASE=./contracts
# NIGHTGATE_PRIVATE_STATE_BACKEND=cap-db               # cap-db (default) | level
# Max time the connectWalletForSigning prewarm job waits for the wallet to sync
# to the chain tip before failing. Raise for far-behind / cold-sync wallets.
# NIGHTGATE_PREWARM_SYNC_TIMEOUT_MS=10800000           # default 3h

# ── Crypto (REQUIRED in production) ───────────────────────────────────────
# 32-byte hex secret used to encrypt viewing/seed keys at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32
# In production srv/utils/crypto.ts throws if this is unset.
ENCRYPTION_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32

# ── Crawler tuning (optional) ─────────────────────────────────────────────
# NIGHTGATE_FETCH_CONCURRENCY=
# NIGHTGATE_RPC_BATCH_SIZE=
# NIGHTGATE_HEAP_MB=                                   # scripts/dev.mjs + serve.mjs

# ── Docker-compose only ───────────────────────────────────────────────────
# Hex-encoded 32-byte secret used by the indexer container to encrypt stored
# sensitive data. The compose default is a known dev placeholder — override
# in production. Generate with: openssl rand -hex 32
# INDEXER_SECRET=
# INDEXER_UPSTREAM_NODE_URL=ws://node:9944

# ── Scripts: wallet sync / T15 / probe-indexer ────────────────────────────
# Consumed by scripts/start-wallet-sync.mjs, scripts/run-t15.mjs,
# scripts/derive-keys.mjs, scripts/probe-indexer.mjs. .env should be
# gitignored — NEVER commit a real wallet seed or mnemonic.
NIGHTGATE_URL=http://localhost:4004
LACE_VIEWING_KEY=XXXXX
LACE_SEED_HEX=XXXXX
# LACE_MNEMONIC=
# INDEXER_URL=
