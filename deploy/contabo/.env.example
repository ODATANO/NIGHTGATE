# Copy to `.env` on the Contabo server

NIGHTGATE_NETWORK=preprod

# Point NIGHTGATE's wallet at the LOCAL indexer (this server), not the public
# one. This is the whole reason for the server: the wallet catch-up runs over
# localhost (sub-ms) instead of stalling on the throttled/lagging public WS.
NIGHTGATE_INDEXER_HTTP_URL=http://localhost:8088/api/v4/graphql
NIGHTGATE_INDEXER_WS_URL=ws://localhost:8088/api/v4/graphql/ws

# Local proof server (from this compose).
NIGHTGATE_PROOF_SERVER_URL=http://localhost:6300

# Submission still goes to the public preprod node RPC (the indexer feeds reads;
# the node accepts the tx). Fine to leave as the public endpoint.
NIGHTGATE_NODE_URL=wss://rpc.preprod.midnight.network/

# Wallet (the funded preprod test wallet). Fill these.
LACE_VIEWING_KEY=
LACE_MNEMONIC=

# AES-256-GCM key for at-rest encryption of viewing/seed keys (64 hex chars).
# Set a real one; without it NIGHTGATE uses an insecure dev fallback.
ENCRYPTION_KEY=

# Optional: a real 32-byte hex (>=1 a-f char) for the indexer's at-rest crypto.
# INDEXER_SECRET=

# Optional: reuse the already-deployed AttestationVault to skip a deploy when
# running the revoke-only / disclosure e2e.
DISCLOSURE_CONTRACT_ADDRESS=29d47194fabe8e9444a5a462b5270897e23b8ede5e395627d6cd00243b65ff93
